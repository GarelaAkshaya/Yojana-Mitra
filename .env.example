```properties
# ============================================
# Yojana Mitra - Example Environment Variables
# ============================================

# Application
APP_NAME=Yojana Mitra
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,te

# Data Paths
DATA_DIR=data
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
CACHE_DIR=data/cache

# Database
DB_PATH=data/yojana_mitra.sqlite3
FAISS_DIR=data/faiss_store

# AI Models
LLM_MODEL_PATH=models/llm/model.gguf
EMBEDDING_MODEL_PATH=models/embeddings/bge-small-en-v1.5
OCR_MODEL_DIR=models/ocr
WHISPER_MODEL_PATH=models/whisper/ggml-small.bin

# Retrieval
TOP_K=5
MIN_CONFIDENCE=0.2

# Chunking
MAX_CHARS=900
OVERLAP_CHARS=120

# LLM
MAX_TOKENS=256
TEMPERATURE=0.1
CONTEXT_WINDOW=4096
```
